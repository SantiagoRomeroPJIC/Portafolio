@model IEnumerable<Portafolio.Models.ProyectoDTO>

<section class="mt-4">
    @if (Model is not null)
    {
        <div class="text-center" style="padding-top: 6rem;">
            <h1>Mis trabajo recientes</h1>
            <p>Aqui puedes ver algunos de mis trabajos mas recientes</p>
        </div>

        <div class="container">
            <div class="row row-cols-1 row-cols-md-2 g-4">
                @foreach (var proyecto in Model)
                {

                    <div class="col">
                        <div class="card h-100">
                            <img src="@proyecto.ImagenURL" class="card-img-top" alt="Imagen proyecto" style="width: 100px" />
                            <div class="card-body">
                                <h5 class="card-title">@proyecto.Titulo</h5>
                                <p class="card-text">@proyecto.Descripcion</p>
                            </div>
                            <div class="card-footer">
                                <a class="btn btn-primary" href="@proyecto.Link" target="_blank" rel="noopener noreferrer">Míralo</a>
                            </div>
                        </div>
                    </div>

                }


            </div>
        </div>
    }
</section>